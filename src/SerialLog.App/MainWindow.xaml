<Window x:Class="SerialLog.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:SerialLog.App.Behaviors"
        xmlns:config="clr-namespace:SerialLog.Core.Configuration;assembly=SerialLog.Core"
        xmlns:views="clr-namespace:SerialLog.App.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Serial Log"
        Icon="Assets/AppIcon.ico"
        Height="950"
        MinHeight="760"
        Width="1500"
        MinWidth="1180"
        WindowState="Maximized"
        Background="#EEF2F6">
<Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="7" Padding="12,7">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Serial Log" FontSize="19" FontWeight="Bold" Margin="0,0,16,0" />
                    <Button Content="保存工作区" Command="{Binding SaveWorkspaceCommand}" />
                    <Button Content="新增窗口" Command="{Binding AddWindowCommand}" />
                    <Button Content="连接全部" Style="{StaticResource PrimaryButton}" Command="{Binding ConnectAllCommand}" />
                    <Button Content="断开全部" Style="{StaticResource DangerButton}" Command="{Binding DisconnectAllCommand}" />
                    <TextBlock Text="{Binding CommandPanelOrientationLabel}" Margin="14,0,4,0" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" />
                    <Button Content="下" Style="{StaticResource CompactButton}" Command="{Binding SetCommandPanelDockCommand}" CommandParameter="{x:Static config:CommandPanelDock.Bottom}" ToolTip="命令区停靠到底部" />
                    <Button Content="上" Style="{StaticResource CompactButton}" Command="{Binding SetCommandPanelDockCommand}" CommandParameter="{x:Static config:CommandPanelDock.Top}" ToolTip="命令区停靠到顶部" />
                    <Button Content="左" Style="{StaticResource CompactButton}" Command="{Binding SetCommandPanelDockCommand}" CommandParameter="{x:Static config:CommandPanelDock.Left}" ToolTip="命令区停靠到左侧" />
                    <Button Content="右" Style="{StaticResource CompactButton}" Command="{Binding SetCommandPanelDockCommand}" CommandParameter="{x:Static config:CommandPanelDock.Right}" ToolTip="命令区停靠到右侧" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="上一页"
                            AllowDrop="True"
                            Drop="PreviousPageButton_Drop"
                            Command="{Binding PreviousPageCommand}"
                            ToolTip="点击翻页；拖动串口窗口到这里可移动到上一页" />
                    <Border Background="{StaticResource AccentSoftBrush}" BorderBrush="#B8DDF2" BorderThickness="1" CornerRadius="10" Padding="9,2" Margin="8,0">
                        <TextBlock Text="{Binding PageLabel}" VerticalAlignment="Center" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                    </Border>
                    <Button Content="下一页"
                            AllowDrop="True"
                            Drop="NextPageButton_Drop"
                            Command="{Binding NextPageCommand}"
                            ToolTip="点击翻页；拖动串口窗口到这里可移动到下一页" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="日志目录" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" />
                    <TextBox Width="360" FontFamily="Consolas" Text="{Binding LogRootDirectory, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <DockPanel Grid.Row="1" LastChildFill="True">
        <Border DockPanel.Dock="{Binding CommandPanelDockEdge}"
                Width="{Binding CommandPanelWidth}"
                Height="{Binding CommandPanelHeight}"
                Margin="{Binding CommandPanelMargin}"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="7"
                Padding="10">
            <views:CommandPanelView />
        </Border>

        <ItemsControl ItemsSource="{Binding CurrentPageWindows}" Margin="0,12,0,12">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="2" Columns="3" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid>
                    <Border Margin="6"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="7"
                            AllowDrop="True"
                            ToolTip="拖动空白区域可调整窗口顺序"
                            PreviewMouseLeftButtonDown="SerialWindowCard_PreviewMouseLeftButtonDown"
                            PreviewMouseMove="SerialWindowCard_PreviewMouseMove"
                            Drop="SerialWindowCard_Drop">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAddSlot}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <DockPanel DataContext="{Binding Window}">
                            <Border DockPanel.Dock="Top"
                                    Background="{StaticResource PanelAltBrush}"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="0,0,0,1"
                                    Padding="6,4">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="30" />
                                        <RowDefinition Height="14" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="102" />
                                        <ColumnDefinition Width="86" />
                                        <ColumnDefinition Width="68" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="44" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Row="0"
                                              Grid.Column="0"
                                              IsChecked="{Binding IsSelectedForSend}"
                                              VerticalAlignment="Center"
                                              ToolTip="参与单条命令发送" />
                                    <TextBox Grid.Row="0"
                                             Grid.Column="1"
                                             Width="96"
                                             Margin="3,0"
                                             Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource TitleTextBox}" />
                                    <ComboBox Grid.Row="0"
                                              Grid.Column="2"
                                              Width="80"
                                              Margin="2,0"
                                              ItemsSource="{Binding AvailablePorts}"
                                              SelectedItem="{Binding PortName}"
                                              ToolTip="端口" />
                                    <TextBox Grid.Row="0"
                                             Grid.Column="3"
                                             Width="62"
                                             Margin="2,0"
                                             Text="{Binding BaudRate, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="波特率" />
                                    <Button Grid.Row="0"
                                            Grid.Column="4"
                                            Content="刷新"
                                            MinWidth="42"
                                            Style="{StaticResource CompactButton}"
                                            Command="{Binding RefreshPortsCommand}"
                                            ToolTip="刷新端口" />
                                    <Button Grid.Row="0"
                                            Grid.Column="5"
                                            Content="{Binding ConnectionActionText}"
                                            MinWidth="42"
                                            Style="{StaticResource ToggleConnectionButton}"
                                            Command="{Binding ToggleConnectionCommand}" />
                                    <CheckBox Grid.Row="0"
                                              Grid.Column="6"
                                              Margin="4,0"
                                              IsChecked="{Binding AutoSaveEnabled}"
                                              VerticalAlignment="Center"
                                              ToolTip="自动保存" />
                                    <Button Grid.Row="0"
                                            Grid.Column="7"
                                            Content="清空"
                                            MinWidth="42"
                                            Style="{StaticResource CompactButton}"
                                            Command="{Binding ClearCommand}"
                                            ToolTip="清空日志" />
                                    <Button Grid.Row="0"
                                            Grid.Column="8"
                                            Content="&#xE74D;"
                                            Style="{StaticResource IconDangerButton}"
                                            Command="{Binding DataContext.RemoveWindowCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="删除窗口" />
                                    <Ellipse Grid.Row="0"
                                             Grid.Column="10"
                                             Width="10"
                                             Height="10"
                                             Fill="{Binding ConnectionIndicatorBrush}"
                                             Stroke="#FFFFFF"
                                             StrokeThickness="1"
                                             HorizontalAlignment="Right"
                                             VerticalAlignment="Top"
                                             Margin="5,1,0,0"
                                             ToolTip="{Binding StatusText}" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="10"
                                               Text="{Binding LineCount}"
                                               Width="44"
                                               HorizontalAlignment="Right"
                                               TextAlignment="Right"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               Foreground="{StaticResource MutedBrush}"
                                               ToolTip="接收行数" />
                                </Grid>
                            </Border>

                            <ListBox ItemsSource="{Binding Lines}"
                                     behaviors:ListBoxAutoScroll.IsEnabled="True"
                                     Background="#FFFFFF"
                                     BorderBrush="{StaticResource BorderBrushSoft}"
                                     Foreground="#111827"
                                     Margin="8"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     ScrollViewer.CanContentScroll="True"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="White" />
                                        <Setter Property="Foreground" Value="#111827" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Text}" TextWrapping="NoWrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#111827" />
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMatch}" Value="True">
                                                            <Setter Property="Foreground" Value="#111827" />
                                                            <Setter Property="Background" Value="#FDE68A" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>
                    <Button Content="+"
                            Width="72"
                            Height="72"
                            FontSize="36"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Command="{Binding DataContext.AddWindowCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Background" Value="#F8FBFE" />
                                <Setter Property="BorderBrush" Value="#B8DDF2" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAddSlot}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        </DockPanel>

        <Border Grid.Row="2" Background="#E4EAF1" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1,0,1,1" Padding="9,4">
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource MutedBrush}" />
        </Border>
    </Grid>
</Window>
