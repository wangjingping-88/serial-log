<Window x:Class="SerialLog.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:SerialLog.App.Behaviors"
        xmlns:controls="clr-namespace:SerialLog.App.Controls"
        xmlns:config="clr-namespace:SerialLog.Core.Configuration;assembly=SerialLog.Core"
        xmlns:converters="clr-namespace:SerialLog.App.Converters"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:views="clr-namespace:SerialLog.App.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Serial Log"
        Icon="Assets/AppIcon.ico"
        Height="950"
        MinHeight="760"
        Width="1500"
        MinWidth="1180"
        WindowState="Maximized"
        Background="#EEF2F6">
    <Window.Resources>
        <converters:WorkspaceScaleConverter x:Key="WorkspaceScaleConverter" />

        <Style x:Key="ScrollBarRepeatButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SlimScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="12" />
            <Setter Property="Height" Value="12" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground"
                    Value="{Binding DataContext.OwnerHeaderBrush,
                                    RelativeSource={RelativeSource AncestorType={x:Type ListBox}},
                                    FallbackValue={StaticResource BorderBrushSoft}}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Root" Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   Orientation="{TemplateBinding Orientation}"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton x:Name="DecreaseButton"
                                                  Command="{x:Static ScrollBar.PageUpCommand}"
                                                  CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                                  Style="{StaticResource ScrollBarRepeatButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb"
                                           Background="{TemplateBinding Foreground}"
                                           Width="4"
                                           Height="{x:Static sys:Double.NaN}"
                                           HorizontalAlignment="Center">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="3" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton x:Name="IncreaseButton"
                                                  Command="{x:Static ScrollBar.PageDownCommand}"
                                                  CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                                  Style="{StaticResource ScrollBarRepeatButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                                <Setter TargetName="DecreaseButton" Property="Command" Value="{x:Static ScrollBar.PageLeftCommand}" />
                                <Setter TargetName="IncreaseButton" Property="Command" Value="{x:Static ScrollBar.PageRightCommand}" />
                                <Setter TargetName="Thumb" Property="Width" Value="{x:Static sys:Double.NaN}" />
                                <Setter TargetName="Thumb" Property="Height" Value="4" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Stretch" />
                                <Setter TargetName="Thumb" Property="VerticalAlignment" Value="Center" />
                            </Trigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Orientation, RelativeSource={RelativeSource TemplatedParent}}" Value="Vertical" />
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource TemplatedParent}}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="Thumb" Property="Width" Value="10" />
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Orientation, RelativeSource={RelativeSource TemplatedParent}}" Value="Horizontal" />
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource TemplatedParent}}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="Thumb" Property="Height" Value="10" />
                            </MultiDataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="{x:Static sys:Double.NaN}" />
                    <Setter Property="Height" Value="12" />
                </Trigger>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="12" />
                    <Setter Property="Height" Value="{x:Static sys:Double.NaN}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource SlimScrollBarStyle}" />
    </Window.Resources>

    <Grid x:Name="WorkspaceViewport" ClipToBounds="True">
    <Grid HorizontalAlignment="Left" VerticalAlignment="Top">
        <Grid.Width>
            <MultiBinding Converter="{StaticResource WorkspaceScaleConverter}" ConverterParameter="Width">
                <Binding Path="ActualWidth" ElementName="WorkspaceViewport" />
                <Binding Path="ActualHeight" ElementName="WorkspaceViewport" />
            </MultiBinding>
        </Grid.Width>
        <Grid.Height>
            <MultiBinding Converter="{StaticResource WorkspaceScaleConverter}" ConverterParameter="Height">
                <Binding Path="ActualWidth" ElementName="WorkspaceViewport" />
                <Binding Path="ActualHeight" ElementName="WorkspaceViewport" />
            </MultiBinding>
        </Grid.Height>
        <Grid.LayoutTransform>
            <ScaleTransform>
                <ScaleTransform.ScaleX>
                    <MultiBinding Converter="{StaticResource WorkspaceScaleConverter}">
                        <Binding Path="ActualWidth" ElementName="WorkspaceViewport" />
                        <Binding Path="ActualHeight" ElementName="WorkspaceViewport" />
                    </MultiBinding>
                </ScaleTransform.ScaleX>
                <ScaleTransform.ScaleY>
                    <MultiBinding Converter="{StaticResource WorkspaceScaleConverter}">
                        <Binding Path="ActualWidth" ElementName="WorkspaceViewport" />
                        <Binding Path="ActualHeight" ElementName="WorkspaceViewport" />
                    </MultiBinding>
                </ScaleTransform.ScaleY>
            </ScaleTransform>
        </Grid.LayoutTransform>
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="7" Padding="12,7">
            <Grid x:Name="TopToolbarViewport" ClipToBounds="True">
                <Grid VerticalAlignment="Center" HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Serial Log"
                               FontSize="19"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Padding="0,1,0,0"
                               Margin="0,0,8,0" />
                    <TextBlock Text="{Binding AppBuildStatusText}"
                               FontSize="11"
                               Foreground="{StaticResource MutedBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"
                               ToolTip="应用版本 / 多机协作协议版本" />
                    <Button Content="新增页" Command="{Binding AddPageCommand}" />
                    <Button Content="删除页"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding RemoveCurrentPageCommand}"
                            ToolTip="仅当前页为空时可删除" />
                    <Button Content="{Binding ToggleAllConnectionsActionText}"
                            Command="{Binding ToggleAllConnectionsCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasConnectedLocalSerialWindows}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                        <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                                        <Setter Property="BorderBrush" Value="#F3B8B4" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Border Margin="12,0,8,0"
                            Padding="7,4"
                            Background="#F8FBFE"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="6"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="多机协作"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource MutedBrush}"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <ComboBox Width="74"
                                      Margin="0,0,6,0"
                                      ItemsSource="{Binding WorkspaceModeOptions}"
                                      SelectedValuePath="Mode"
                                      SelectedValue="{Binding WorkspaceMode}"
                                      ToolTip="本地：单机使用；主机：监听其他 PC；客户端：连接主机">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBox Width="92"
                                     Margin="0,0,6,0"
                                     Text="{Binding LocalPcName, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="本机名称，主机端用它标识窗口来源" />
                            <ComboBox x:Name="PcColorComboBox"
                                      Width="86"
                                      Margin="0,0,6,0"
                                      HorizontalContentAlignment="Left"
                                      ItemsSource="{Binding PcColorOptions}"
                                      SelectedItem="{Binding SelectedPcColorOption}"
                                      ToolTip="本机窗口颜色；自动会按本机名生成固定颜色">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Left">
                                            <Border Width="12"
                                                    Height="12"
                                                    Margin="0,0,6,0"
                                                    Background="{Binding Hex}"
                                                    BorderBrush="#FFFFFF"
                                                    BorderThickness="1" />
                                            <TextBlock Text="{Binding Name}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Text="主机"
                                       FontSize="11"
                                       Foreground="{StaticResource MutedBrush}"
                                       Margin="0,0,4,0"
                                       VerticalAlignment="Center" />
                            <TextBox Width="118"
                                     Margin="0,0,6,0"
                                     FontFamily="Consolas"
                                     Text="{Binding HostAddress, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="主机模式会自动填本机 IPv4；客户端模式填写主机 PC 的 IPv4" />
                            <TextBlock Text="端口"
                                       FontSize="11"
                                       Foreground="{StaticResource MutedBrush}"
                                       Margin="0,0,4,0"
                                       VerticalAlignment="Center" />
                            <TextBox Width="58"
                                     Margin="0,0,6,0"
                                     FontFamily="Consolas"
                                     Text="{Binding HostPort, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="主机端口" />
                            <Button Content="{Binding StartCollaborationActionText}"
                                    Style="{StaticResource CompactButton}"
                                    Command="{Binding StartCollaborationCommand}"
                                    ToolTip="按当前模式启动主机或连接主机" />
                            <Button Content="停止"
                                    Style="{StaticResource CompactDangerButton}"
                                    Command="{Binding StopCollaborationCommand}"
                                    ToolTip="停止协作连接" />
                        </StackPanel>
                    </Border>
                    </StackPanel>
                    <Border Grid.Column="1"
                            Margin="8,0,8,0"
                            Padding="7,4"
                            Background="#F8FBFE"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="6"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="命令区"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource MutedBrush}"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <Button Content="下" Command="{Binding SetCommandPanelDockCommand}" CommandParameter="{x:Static config:CommandPanelDock.Bottom}" ToolTip="命令区停靠到底部">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource CompactButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CommandPanelDock}" Value="{x:Static config:CommandPanelDock.Bottom}">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="上" Command="{Binding SetCommandPanelDockCommand}" CommandParameter="{x:Static config:CommandPanelDock.Top}" ToolTip="命令区停靠到顶部">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource CompactButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CommandPanelDock}" Value="{x:Static config:CommandPanelDock.Top}">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="左" Command="{Binding SetCommandPanelDockCommand}" CommandParameter="{x:Static config:CommandPanelDock.Left}" ToolTip="命令区停靠到左侧">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource CompactButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CommandPanelDock}" Value="{x:Static config:CommandPanelDock.Left}">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="右" Command="{Binding SetCommandPanelDockCommand}" CommandParameter="{x:Static config:CommandPanelDock.Right}" ToolTip="命令区停靠到右侧">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource CompactButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CommandPanelDock}" Value="{x:Static config:CommandPanelDock.Right}">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="{Binding CommandPanelVisibilityActionText}"
                                    Command="{Binding ToggleCommandPanelVisibilityCommand}"
                                    ToolTip="隐藏命令区，仅查看日志；再次点击显示命令区">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource CompactButton}">
                                        <Setter Property="MinWidth" Value="42" />
                                        <Setter Property="Margin" Value="6,0,0,0" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCommandPanelHidden}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Margin="6,0,0,0"
                            Padding="7,4"
                            Background="#F8FBFE"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="6"
                            VerticalAlignment="Center">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="日志目录"
                                       Grid.Column="0"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource MutedBrush}"
                                       Margin="0,0,8,0" />
                            <TextBox Grid.Column="1"
                                     MinWidth="80"
                                     FontFamily="Consolas"
                                     Text="{Binding LogRootDirectory, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="2"
                                    Content="浏览"
                                    Margin="6,0,0,0"
                                    Padding="10,2"
                                    ToolTip="选择日志保存目录"
                                    Click="BrowseLogRootDirectoryButton_Click" />
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                        <Button Content="上一页"
                                AllowDrop="True"
                                Drop="PreviousPageButton_Drop"
                                Command="{Binding PreviousPageCommand}"
                                ToolTip="点击翻页；拖动串口窗口到这里可移动到上一页" />
                        <Border Background="{StaticResource AccentSoftBrush}" BorderBrush="#B8DDF2" BorderThickness="1" CornerRadius="10" Padding="9,2" Margin="8,0">
                            <TextBlock Text="{Binding PageLabel}" VerticalAlignment="Center" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                        </Border>
                        <Button Content="下一页"
                                AllowDrop="True"
                                Drop="NextPageButton_Drop"
                                Command="{Binding NextPageCommand}"
                                ToolTip="点击翻页；拖动串口窗口到这里可移动到下一页" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <DockPanel Grid.Row="1" LastChildFill="True">
        <Border x:Name="CommandPanelHost"
                DockPanel.Dock="{Binding CommandPanelDockEdge}"
                Width="{Binding CommandPanelWidth}"
                Height="{Binding CommandPanelHeight}"
                Margin="{Binding CommandPanelMargin}"
                Visibility="{Binding CommandPanelVisibility}"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="7"
                Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="26" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0"
                        Background="{StaticResource PanelAltBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="0,0,0,1"
                        Cursor="SizeAll"
                        PreviewMouseLeftButtonDown="CommandPanelHeader_PreviewMouseLeftButtonDown"
                        PreviewMouseMove="CommandPanelHeader_PreviewMouseMove"
                        ToolTip="拖动到软件外部可浮动命令区">
                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Right"
                                Content="浮动"
                                Style="{StaticResource CompactButton}"
                                Command="{Binding FloatCommandPanelCommand}"
                                ToolTip="将命令区浮动成独立窗口" />
                        <TextBlock Text="命令区"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedBrush}"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                </Border>
                <views:CommandPanelView Grid.Row="1" />
            </Grid>
        </Border>

        <ItemsControl ItemsSource="{Binding CurrentPageWindows}" Margin="0,10,0,4">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <controls:SerialWindowGridPanel Rows="{Binding SerialGridRows}" Columns="{Binding SerialGridColumns}" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid>
                    <Border Margin="6"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{Binding Window.OwnerBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="7"
                            AllowDrop="True"
                            ToolTip="拖动空白区域可调整窗口顺序"
                            PreviewMouseLeftButtonDown="SerialWindowCard_PreviewMouseLeftButtonDown"
                            PreviewMouseMove="SerialWindowCard_PreviewMouseMove"
                            Drop="SerialWindowCard_Drop">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsAddSlot}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <DockPanel DataContext="{Binding Window}">
                            <Border DockPanel.Dock="Top"
                                    Background="{Binding OwnerHeaderBrush}"
                                    BorderBrush="{Binding OwnerBorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="6,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="44" />
                                    </Grid.ColumnDefinitions>
                                    <Viewbox Grid.Column="0"
                                             Margin="0,0,6,0"
                                             Stretch="Uniform"
                                             StretchDirection="DownOnly"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Top">
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox IsChecked="{Binding IsSelectedForSend}"
                                                      VerticalAlignment="Center"
                                                      ToolTip="参与单条命令发送" />
                                            <TextBox Width="96"
                                                     Margin="3,0"
                                                     Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource TitleTextBox}" />
                                            <ComboBox Width="80"
                                                      Margin="2,0"
                                                      ItemsSource="{Binding AvailablePorts}"
                                                      SelectedItem="{Binding PortName}"
                                                      IsEnabled="{Binding IsLocalSerial}"
                                                      ToolTip="端口" />
                                            <ComboBox Width="76"
                                                      Margin="2,0"
                                                      IsEditable="True"
                                                      IsTextSearchEnabled="False"
                                                      ItemsSource="{Binding BaudRateOptions}"
                                                      Text="{Binding BaudRateText, UpdateSourceTrigger=PropertyChanged}"
                                                      IsEnabled="{Binding IsLocalSerial}"
                                                      ToolTip="波特率" />
                                            <Button Content="刷新"
                                                    MinWidth="42"
                                                    Style="{StaticResource CompactButton}"
                                                    Command="{Binding RefreshPortsCommand}"
                                                    IsEnabled="{Binding IsLocalSerial}"
                                                    ToolTip="刷新端口" />
                                            <Button Content="{Binding ConnectionActionText}"
                                                    MinWidth="42"
                                                    Style="{StaticResource ToggleConnectionButton}"
                                                    Command="{Binding ToggleConnectionCommand}"
                                                    IsEnabled="{Binding IsLocalSerial}"
                                                    ToolTip="远端窗口的连接状态由远端电脑控制" />
                                            <CheckBox Margin="4,0"
                                                      IsChecked="{Binding AutoSaveEnabled}"
                                                      VerticalAlignment="Center"
                                                      Visibility="{Binding AutoSaveToggleVisibility}"
                                                      ToolTip="{Binding AutoSaveToolTip}" />
                                            <Button Content="清空"
                                                    MinWidth="42"
                                                    Style="{StaticResource CompactButton}"
                                                    Command="{Binding ClearCommand}"
                                                    ToolTip="清空日志" />
                                            <Button Content="删除"
                                                    MinWidth="42"
                                                    Style="{StaticResource CompactDangerButton}"
                                                    Command="{Binding DataContext.RemoveWindowCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="删除窗口" />
                                            <Button Content="{Binding DataContext.ExpandActionText, RelativeSource={RelativeSource AncestorType=ContentPresenter}}"
                                                    MinWidth="42"
                                                    Style="{StaticResource CompactButton}"
                                                    Command="{Binding DataContext.ToggleWindowExpansionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ContentPresenter}}"
                                                    ToolTip="当前页下方有空槽时，纵向放大或还原窗口" />
                                            <TextBlock Text="拖动"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Cursor="SizeAll"
                                                       VerticalAlignment="Center"
                                                       Margin="8,5,0,0"
                                                       ToolTip="按住这里拖动排序，也可拖到上一页/下一页" />
                                        </StackPanel>
                                    </Viewbox>
                                    <StackPanel Grid.Column="1"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top">
                                        <Ellipse Width="10"
                                                 Height="10"
                                                 Fill="{Binding ConnectionIndicatorBrush}"
                                                 Stroke="#FFFFFF"
                                                 StrokeThickness="1"
                                                 HorizontalAlignment="Right"
                                                 Margin="0,1,0,6"
                                                 ToolTip="{Binding StatusText}" />
                                        <TextBlock Text="{Binding LineCount}"
                                                   Width="44"
                                                   HorizontalAlignment="Right"
                                                   TextAlignment="Right"
                                                   FontFamily="Consolas"
                                                   FontSize="11"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   ToolTip="接收行数" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <ListBox ItemsSource="{Binding Lines}"
                                     behaviors:ListBoxAutoScroll.IsEnabled="True"
                                     SelectionMode="Extended"
                                     Background="#FFFFFF"
                                     BorderBrush="{StaticResource BorderBrushSoft}"
                                     Foreground="#111827"
                                     Margin="8"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     PreviewKeyDown="LogListBox_PreviewKeyDown"
                                     PreviewMouseRightButtonDown="LogListBox_PreviewMouseRightButtonDown"
                                     ScrollViewer.CanContentScroll="True"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling">
                                <ListBox.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="复制选中日志"
                                                  Click="CopySelectedLogMenuItem_Click" />
                                    </ContextMenu>
                                </ListBox.ContextMenu>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="White" />
                                        <Setter Property="Foreground" Value="#111827" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMatch}" Value="True">
                                                            <Setter Property="Background" Value="#FDE68A" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <ItemsControl ItemsSource="{Binding DisplaySegments}"
                                                          Focusable="False">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Text}"
                                                                   Foreground="{Binding EffectiveForeground}"
                                                                   FontFamily="Consolas"
                                                                   FontSize="12"
                                                                   TextWrapping="NoWrap" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>
                    <Button Content="+"
                            Width="72"
                            Height="72"
                            Focusable="False"
                            FontSize="36"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Command="{Binding DataContext.AddWindowCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Background" Value="#F8FBFE" />
                                <Setter Property="BorderBrush" Value="#B8DDF2" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAddSlot}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        </DockPanel>

        <Border Grid.Row="2" Background="#E4EAF1" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1,0,1,1" Padding="9,4">
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource MutedBrush}" />
        </Border>
    </Grid>
    </Grid>
    </Grid>
</Window>
