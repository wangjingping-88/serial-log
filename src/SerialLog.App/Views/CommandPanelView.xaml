<UserControl x:Class="SerialLog.App.Views.CommandPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
    <Grid.ColumnDefinitions>
    <ColumnDefinition Width="2*" />
    <ColumnDefinition Width="3*" />
    </Grid.ColumnDefinitions>
    <GroupBox Header="单条发送" Foreground="{StaticResource TextBrush}" Margin="0,0,8,0">
    <Grid Margin="8">
    <Grid.RowDefinitions>
    <RowDefinition Height="38" />
    <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <StackPanel Grid.Row="0" Orientation="Horizontal">
    <TextBox Width="360" Text="{Binding CommandText, UpdateSourceTrigger=PropertyChanged}" />
    <ComboBox Width="90" ItemsSource="{Binding LineEndingOptions}" SelectedItem="{Binding SelectedLineEnding}" />
    <Button Content="发送" Style="{StaticResource PrimaryButton}" Command="{Binding SendCommand}" />
    </StackPanel>
    <Grid Grid.Row="1">
    <Grid.ColumnDefinitions>
    <ColumnDefinition Width="*" />
    <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    <GroupBox Header="目标窗口" Foreground="{StaticResource TextBrush}" Margin="0,8,6,0">
    <ItemsControl ItemsSource="{Binding SerialWindows}">
    <ItemsControl.ItemTemplate>
    <DataTemplate>
    <CheckBox Content="{Binding Title}" IsChecked="{Binding IsSelectedForSend}" Margin="6,3" />
    </DataTemplate>
    </ItemsControl.ItemTemplate>
    </ItemsControl>
    </GroupBox>
    <Grid Grid.Column="1" Margin="6,8,0,0">
    <Button Content="清空历史"
    HorizontalAlignment="Right"
    VerticalAlignment="Top"
    Margin="0,-2,8,0"
    Panel.ZIndex="1"
    Style="{StaticResource CompactButton}"
    Command="{Binding ClearCommandHistoryCommand}"
    ToolTip="最多保留 100 条发送历史" />
    <GroupBox Header="发送历史" Foreground="{StaticResource TextBrush}">
    <ListBox ItemsSource="{Binding CommandHistory}"
    SelectedItem="{Binding CommandText, Mode=TwoWay}" />
    </GroupBox>
    </Grid>
    </Grid>
    </Grid>
    </GroupBox>
    
    <GroupBox Grid.Column="1" Header="命令组 / AT 文件" Foreground="{StaticResource TextBrush}" Margin="8,0,0,0">
    <Grid Margin="8">
    <Grid.ColumnDefinitions>
    <ColumnDefinition Width="200" />
    <ColumnDefinition Width="*" />
    <ColumnDefinition Width="280" />
    </Grid.ColumnDefinitions>
    <DockPanel Grid.Column="0">
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
    <StackPanel.Resources>
    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
    <Setter Property="MinWidth" Value="46" />
    <Setter Property="Padding" Value="6,5" />
    <Setter Property="Margin" Value="2,0" />
    </Style>
    </StackPanel.Resources>
    <Button Content="新建" Command="{Binding AddCommandGroupCommand}" />
    <Button Content="复制" Command="{Binding DuplicateCommandGroupCommand}" />
    <Button Content="删除" Style="{StaticResource DangerButton}" Command="{Binding DeleteCommandGroupCommand}" />
    </StackPanel>
    <ListBox ItemsSource="{Binding CommandGroups}" SelectedItem="{Binding SelectedCommandGroup}" DisplayMemberPath="Name" />
    </DockPanel>
    <Grid Grid.Column="1" DataContext="{Binding SelectedCommandGroup}" Margin="8,0">
    <Grid.RowDefinitions>
    <RowDefinition Height="32" />
    <RowDefinition Height="40" />
    <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
    <ColumnDefinition Width="*" />
    <ColumnDefinition Width="Auto" />
    <ColumnDefinition Width="82" />
    <ColumnDefinition Width="90" />
    <ColumnDefinition Width="Auto" />
    </Grid.ColumnDefinitions>
    <TextBox Grid.Row="0" Grid.Column="0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
    <TextBlock Grid.Row="0" Grid.Column="1"
    Text="间隔(ms)"
    Foreground="{StaticResource MutedBrush}"
    VerticalAlignment="Center"
    Margin="8,0,4,0" />
    <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding DelayMilliseconds, UpdateSourceTrigger=PropertyChanged}" ToolTip="命令组内每条命令之间的发送间隔，单位 ms" />
    <ComboBox Grid.Row="0" Grid.Column="3"
    ItemsSource="{Binding DataContext.LineEndingOptions, RelativeSource={RelativeSource AncestorType=Window}}"
    SelectedItem="{Binding LineEnding}" />
    <Button Grid.Row="0" Grid.Column="4" Content="执行" Style="{StaticResource PrimaryButton}"
    Command="{Binding DataContext.ExecuteCommandGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
    <ItemsControl Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5" ItemsSource="{Binding Targets}" Margin="0,8,0,0">
    <ItemsControl.ItemsPanel>
    <ItemsPanelTemplate>
    <WrapPanel />
    </ItemsPanelTemplate>
    </ItemsControl.ItemsPanel>
    <ItemsControl.ItemTemplate>
    <DataTemplate>
    <CheckBox Content="{Binding Title}" IsChecked="{Binding IsSelected}" Margin="4,0,10,0" />
    </DataTemplate>
    </ItemsControl.ItemTemplate>
    </ItemsControl>
    <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5">
    <Grid.RowDefinitions>
    <RowDefinition Height="32" />
    <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <StackPanel Orientation="Horizontal">
    <TextBox Width="360" Text="{Binding NewCommand, UpdateSourceTrigger=PropertyChanged}" />
    <Button Content="加入命令" Style="{StaticResource PrimaryButton}" Command="{Binding DataContext.AddCommandToGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
    </StackPanel>
    <ListBox Grid.Row="1"
    ItemsSource="{Binding Commands}"
    Margin="4"
    AllowDrop="True"
    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
    ToolTip="拖动调整顺序；Delete 删除；右键删除"
    PreviewMouseLeftButtonDown="CommandGroupCommandsListBox_PreviewMouseLeftButtonDown"
    PreviewMouseMove="CommandGroupCommandsListBox_PreviewMouseMove"
    Drop="CommandGroupCommandsListBox_Drop"
    PreviewKeyDown="CommandGroupCommandsListBox_PreviewKeyDown">
    <ListBox.ContextMenu>
    <ContextMenu>
    <MenuItem Header="删除"
    Command="{Binding PlacementTarget.Tag.RemoveCommandFromGroupCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
    CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
    </ContextMenu>
    </ListBox.ContextMenu>
    <ListBox.ItemContainerStyle>
    <Style TargetType="ListBoxItem">
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <EventSetter Event="PreviewMouseRightButtonDown" Handler="ListBoxItem_PreviewMouseRightButtonDown" />
    </Style>
    </ListBox.ItemContainerStyle>
    <ListBox.ItemTemplate>
    <DataTemplate>
    <TextBlock Text="{Binding}"
    FontFamily="Consolas"
    VerticalAlignment="Center"
    TextTrimming="CharacterEllipsis" />
    </DataTemplate>
    </ListBox.ItemTemplate>
    </ListBox>
    </Grid>
    </Grid>
    <DockPanel Grid.Column="2">
    <Grid DockPanel.Dock="Top" Margin="0,-2,0,6">
    <Grid.RowDefinitions>
    <RowDefinition Height="20" />
    <RowDefinition Height="30" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
    <ColumnDefinition Width="*" />
    <ColumnDefinition Width="Auto" />
    </Grid.ColumnDefinitions>
    <TextBlock Grid.Row="0"
    Grid.Column="0"
    Text="命令导入"
    Foreground="{StaticResource MutedBrush}"
    FontWeight="SemiBold"
    VerticalAlignment="Center" />
    <TextBlock Grid.Row="0"
    Grid.Column="1"
    Text="{Binding ImportedAtCommands.Count, StringFormat=共 {0} 条}"
    Foreground="{StaticResource MutedBrush}"
    FontFamily="Consolas"
    VerticalAlignment="Center"
    HorizontalAlignment="Right" />
    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal">
    <StackPanel.Resources>
    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
    <Setter Property="MinWidth" Value="52" />
    <Setter Property="Padding" Value="6,4" />
    <Setter Property="Margin" Value="2,0" />
    </Style>
    </StackPanel.Resources>
    <Button Content="导入AT" Command="{Binding ImportAtFileCommand}" ToolTip="覆盖导入 AT 文件" />
    <Button Content="追加AT" Command="{Binding AppendAtFileCommand}" ToolTip="追加 AT 文件" />
    <Button Content="自定义" Command="{Binding CustomAtImportCommand}" ToolTip="手动输入命令，一行一条" />
    <Button Content="入组" Style="{StaticResource PrimaryButton}" Command="{Binding AddAtCommandToGroupCommand}" ToolTip="先填入中间编辑框，修改参数后再加入命令组" />
    </StackPanel>
    </Grid>
    <ListBox ItemsSource="{Binding ImportedAtCommands}"
    SelectedItem="{Binding SelectedAtCommand}"
    FontFamily="Consolas"
    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
    PreviewKeyDown="ImportedAtCommandsListBox_PreviewKeyDown">
    <ListBox.ContextMenu>
    <ContextMenu>
    <MenuItem Header="删除"
    Command="{Binding PlacementTarget.Tag.RemoveImportedAtCommandCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
    CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
    </ContextMenu>
    </ListBox.ContextMenu>
    <ListBox.ItemContainerStyle>
    <Style TargetType="ListBoxItem">
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <EventSetter Event="PreviewMouseRightButtonDown" Handler="ListBoxItem_PreviewMouseRightButtonDown" />
    </Style>
    </ListBox.ItemContainerStyle>
    <ListBox.ItemTemplate>
    <DataTemplate>
    <TextBlock Text="{Binding}"
    FontFamily="Consolas"
    VerticalAlignment="Center"
    TextTrimming="CharacterEllipsis" />
    </DataTemplate>
    </ListBox.ItemTemplate>
    </ListBox>
    </DockPanel>
    </Grid>
    </GroupBox>
    </Grid>
</UserControl>
